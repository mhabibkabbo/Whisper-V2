<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.drafts.LoginController">
   <children>
      <Pane layoutY="-1.0" prefHeight="400.0" prefWidth="603.0" styleClass="light-gray-background" stylesheets="@style.css">
         <children>
            <TextField fx:id="usernameField" layoutX="169.0" layoutY="115.0" prefHeight="35.0" prefWidth="258.0" styleClass="white-background" stylesheets="@style.css" />
            <PasswordField fx:id="passwordField" layoutX="169.0" layoutY="172.0" prefHeight="35.0" prefWidth="258.0" styleClass="white-background" stylesheets="@style.css" />
            <Button fx:id="loginButton" layoutX="271.0" layoutY="241.0" mnemonicParsing="false" text="Login" onAction="#handleLogin"/>
            <Text layoutX="207.0" layoutY="303.0" strokeType="OUTSIDE" strokeWidth="0.0" text="No Account? Register here" />
            <Button fx:id="signUpButton" layoutX="379.0" layoutY="283.0" mnemonicParsing="false" onAction="#switchToRegistrationScene" text="Sign Up" />
         </children>
      </Pane>
   </children>
</AnchorPane>
