<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="root" styleClass="background" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.drafts.controllers.LoginSignup">
    <AnchorPane fx:id="container">
        <Group AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0">
            <fx:include fx:id="appLogo" source="../svg/logo.fxml" />
        </Group>

        <Label styleClass="app-title" text="Whisper" AnchorPane.leftAnchor="160.0" AnchorPane.topAnchor="15.0" />

        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <VBox fx:id="loginPanel" alignment="CENTER" fillWidth="false" spacing="20.0">
                <Label styleClass="form-heading" text="Login" />
                <TextField fx:id="usernameFieldLogin" prefHeight="50.0" prefWidth="450.0" promptText="Username" />
                <PasswordField onAction="#onLogin" fx:id="passwordFieldLogin" prefHeight="50.0" prefWidth="450.0" promptText="Password" />
                <Button onAction="#onLogin" prefHeight="50.0" prefWidth="120.0" text="Login" />
                <HBox alignment="CENTER" spacing="5.0">
                    <Label styleClass="link-text" text="Don't have an account?" />
                    <Hyperlink styleClass="link-text" onAction="#onSignUpLink" text="Sign up" />
                </HBox>
            </VBox>

            <VBox fx:id="signupPanel" alignment="CENTER" fillWidth="false" spacing="20.0" >
                <Label styleClass="form-heading" text="Sign Up" />
                <StackPane onMouseClicked="#handlePickImage">
                    <Circle radius="62.5" styleClass="pfp-circle"/>
                    <fx:include source="../svg/icon_user.fxml" />
                    <ImageView fx:id="profilePreview"
                               fitWidth="125" fitHeight="125"
                    />
                </StackPane>
                <TextField fx:id="nameFieldSignup" prefHeight="50.0" prefWidth="500.0" promptText="Name" />
                <TextField fx:id="usernameFieldSignup" prefHeight="50.0" prefWidth="500.0" promptText="Username" />
                <HBox alignment="CENTER" spacing="20.0">
                    <PasswordField fx:id="passwordFieldSignup" prefHeight="50.0" prefWidth="240.0" promptText="Password" />
                    <PasswordField fx:id="confirmPasswordFieldSignup" onAction="#onSignUp" prefHeight="50.0" prefWidth="240.0" promptText="Confirm Password" />
                </HBox>
                <Button onAction="#onSignUp" prefHeight="50.0" prefWidth="120.0" text="Sign Up" />
                <HBox alignment="CENTER" spacing="5.0">
                    <Label styleClass="link-text" text="Already have an account?" />
                    <Hyperlink styleClass="link-text" onAction="#onLoginLink" text="Login" />
                </HBox>
            </VBox>
        </StackPane>
    </AnchorPane>
</StackPane>
